{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "next dev --hostname 0.0.0.0",
    "dev:emulators": "npx -y firebase-tools@latest emulators:start --project buffet-493105 --only auth",
    "dev:emulators:all": "npx -y firebase-tools@latest emulators:start --project buffet-493105 --only auth,firestore,functions,storage",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "lint": "eslint",
    "test:rules": "vitest run tests/rules",
    "emu:rules": "firebase emulators:exec --only firestore \"vitest run tests/rules\"",
    "emu": "firebase emulators:start --only auth,firestore,functions",
    "seed": "tsx --env-file-if-exists=.env.local scripts/seed.ts",
    "seed:emu": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-table": "^8.21.3",
    "@vis.gl/react-google-maps": "^1.8.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.73.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
